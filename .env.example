# Supabase project credentials
# Found in Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-side only, never expose to the client.
# Used for admin actions (e.g. creating restricted HQ accounts).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Shared access code required to create a new HQ admin account from the
# /signup page. Distribute this out-of-band (not via the app itself) to
# whoever the founder authorizes to create staff accounts.
HQ_SIGNUP_CODE=change-me-before-deploying
