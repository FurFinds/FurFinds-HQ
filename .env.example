# Supabase project credentials
# Found in Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-side only, never expose to the client.
# Used for admin actions (e.g. creating restricted HQ accounts).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Shared access code required to create a new HQ admin account from the
# /signup page. Distribute this out-of-band (not via the app itself) to
# whoever the founder authorizes to create staff accounts.
HQ_SIGNUP_CODE=change-me-before-deploying

# Anthropic API key for AI-assisted tier verification suggestions on
# applications (src/lib/ai/verification.ts). Add this in your hosting
# provider's environment variables (e.g. Vercel Project Settings >
# Environment Variables) — do not put the real key in this file.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Set to "true" once ANTHROPIC_API_KEY (above) is set. Until then, the
# "Run AI Analysis" button on verification applications stays disabled
# with a "Coming soon" label instead of erroring when clicked.
NEXT_PUBLIC_AI_VERIFICATION_ENABLED=false

# Resend API key + verified sender for the email composer in Customer
# Success (src/lib/email/resend.ts). Add these in your hosting provider's
# environment variables — do not put the real key in this file. RESEND_FROM
# must use a domain verified in your Resend account, or sends will fail.
RESEND_API_KEY=re_your-key-here
RESEND_FROM="FurFinds HQ <hq@furfinds.com>"
